INSERT INTO `temp` (`id`, `name`, `description`, `short_description`) VALUES
(1, 'A.D.Xenopol', 'Colegiul Economic A.D. Xenopol are o istorie de 130 de ani, timp în care a construit o perspectivă puternică asupra dezvoltării academice și non-academice armonioase a elevilor săi.\n\nCu o viziune internațională puternică, îi încurajează pe elevi să privească dincolo de granițe pentru studiile superioare. Acest lucru este evidențiat de curriculumul bogat în limbi străine precum chineză, engleză, spaniolă, turcă și greacă, dar și de proiectele internaționale în care Colegiul este implicat.', 'Colegiu economic cu o tradiție de 130 de ani, cu puternică orientare internațională și curriculum bogat în limbi străine (chineză, engleză, spaniolă, turcă, greacă).'),
(2, 'Ady Endre', 'Meşteşugarii şi comercianţii din cetăţile medievale aveau nevoie de scutul protector al oştenilor pricepuţi în arta războiului. Între aceştia, oştenii maghiari şi-au făcut prezenţa în burgurile Moldovei şi Ţării Româneşti încă din secolul al XV-lea.\n\nPeste vreme, meleagurile bucureştene le deveniseră loc de refugiu, în perioadele de restrişte.\n\nUn alt exod al maghiarilor spre Bucureşti s-a produs în timpul Revoluţiei din 1848-1849, continuat cu al treilea aflux din perioada interbelică.\n\nPrin prezenţa lor seculară, maghiarii reuşesc să se remarce în viaţa social-politică a Capitalei României, păstrându-şi obiceiurile, limba şi credinţa în Dumnezeu, indiferent de rit: evanghelic, catolic sau calvin.\n\nCei ce i-au cunoscut îndeaproape, afirmă că au o capacitate de adaptare ieşită din comun, că îi simpatizează pe cei harnici, că îşi triesc viaţa la maximum de intensitate şi îi dispreţuiesc pe profitori', 'Liceu teoretic cu predare în limba maghiară, care păstrează tradiția și identitatea comunității maghiare din București.'),
(3, 'Alexandru Ioan Cuza', 'Liceul Teoretic „Alexandru Ioan Cuza” din Bucureşti s-a înfiinţat la 1 septembrie 1967, cu numele de „Liceul de Cultură Generală nr. 43”. Din anul 1977 şi până în 1993, s-a numit „Liceul de Matematică - Fizică Nr.3”, siglă cu care s-a impus constant ca un liceu de elită, deşi a fost în competiţie cu multe licee bucureştene ca „N. Bălcescu”, „Mihai Viteazul”, „Gheorghe Lazăr”, „I.L. Caragiale”, „Iulia Haşdeu”, astăzi devenite Colegii Naţionale.\nMenţionăm că o dovadă a recunoaşterii valorii sale în perioada respectivă, a fost chiar faptul că, într-o epocă în care majoritatea liceelor au fost transformate în licee industriale, acesta a rămas unul dintre cele cinci licee din Bucureşti acceptate ca liceu de matematică - fizică.', 'Liceu teoretic înființat în 1967 (fost Liceul de Matematică–Fizică nr. 3), recunoscut ca liceu de elită pe profil real.'),
(4, 'Alexandru Vlahuță', 'Școala din Floreasca a fost înființată în 1891 pentru copiii din cătunul Floreasca, care până atunci mergeau la școli din localitățile vecine. La început a funcționat în spații închiriate și cu puțini elevi.\n\nÎn 1919, școala s-a împărțit în școală de fete și școală de băieți, iar în 1925–1926 a fost construită clădirea proprie. După reformele din învățământ, instituția a primit diferite denumiri, devenind Școala Generală nr. 15.\n\nÎn 1968, școala a fost extinsă cu o nouă aripă, pentru a face față numărului tot mai mare de elevi. Astfel, dintr-o mică școală rurală, a devenit o instituție importantă a cartierului Floreasca.', 'Școală din cartierul Floreasca, înființată în 1891, devenită dintr-o mică școală rurală o instituție importantă a cartierului.'),
(5, 'Anghel Saligny', 'Colegiul Tehnic „Anghel Saligny” a fost înființat în 1966 sub denumirea de Liceul Industrial de Construcții. De-a lungul timpului, instituția și-a schimbat numele în Liceul de Construcții nr. 1 (1976), Grupul Școlar Industrial de Construcții Montaj nr. 1 (1991), iar din 2009 poartă numele de Colegiul Tehnic „Anghel Saligny”.\n\nDin 1994, școala a participat la programul Phare-VET, beneficiind de dotări moderne pentru laboratoare și ateliere. Astăzi, oferă calificări în domeniile construcții, instalații, mecanică și electric, precum și pregătire sportivă și cursuri de formare profesională pentru adulți.\n\nColegiul este frecventat de elevi din București și din județele învecinate, punând la dispoziție și cazare în cămin pentru cei din alte localități.', 'Colegiu tehnic înființat în 1966, cu calificări în construcții, instalații, mecanică și electric și cu pregătire sportivă.'),
(6, 'Aurel Vlaicu', 'Colegiul Național „Aurel Vlaicu” a fost înființat în 1922 de muncitorii ceferiști și a funcționat inițial ca școală mixtă. Numele instituției a fost ales în memoria aviatorului Aurel Vlaicu.\n\nDupă distrugerile suferite în timpul celui de-Al Doilea Război Mondial, școala și-a reluat activitatea în 1946. În 1957 a reprimit numele „Aurel Vlaicu”, iar în 1970 a devenit liceu de cultură generală cu profil matematică-fizică.\n\nÎn 1974, instituția s-a transformat în Liceul Industrial nr. 10, iar din 1990 a redevenit Liceul Teoretic „Aurel Vlaicu”, având profiluri teoretice și vocaționale. Din 2004, poartă denumirea de Colegiul Național Aurel Vlaicu.', 'Colegiu național înființat în 1922, numit după aviatorul Aurel Vlaicu, cu profiluri teoretice și vocaționale.'),
(7, 'Benjamin Franklin', 'Liceul Teoretic „Benjamin Franklin” poartă numele unuia dintre marii fizicieni şi oameni de stat americani, autorul a numeroase invenţii şi descoperiri. Numele a fost dat Grupului Şcolar „Optica Română” în cadrul unei ceremonii la care au participat Ministrul Educaţiei şi Cercetării, Domnul Andrei Marga şi Ambasadorul Statelor Unite ale Americii la Bucureşti, Domnul James Rosapepe.\n\nÎnfiinţat în 1970 mai întâi ca Şcoala profesională „I.O.R.”, apoi ca Liceul industrial „I.O.R.” pentru a pregăti forţa de muncă necesară Intreprinderii Optice Române, a fost singurul liceu de optică din ţară.\n\nÎn anul 1999, îşi schimbă denumirea în “Grupul Şcolar Benjamin Franklin”.\n\nÎncepând cu anul 2000, se transformă în liceu teoretic.\n\nDin anul şcolar 2003 – 2004 îşi schimbă numele în „Liceul Teoretic Benjamin Franklin”.', 'Liceu teoretic, fost singurul liceu de optică din țară, devenit teoretic în anul 2000.'),
(8, 'C.A. Rosetti', 'Liceul Teoretic C.A. Rosetti a fost înființat în 1957, pe locul fostei Școli muncitorești nr. 3. În 1959, școala a primit numele „C.A. Rosetti” și s-a mutat în actualul sediu din cartierul Floreasca, construit cu sprijinul profesorilor, elevilor și locuitorilor din zonă.\n\nDe-a lungul timpului, profilul liceului s-a schimbat în funcție de cerințele educaționale: a fost liceu de limba engleză (1968), liceu de chimie-biologie și chimie industrială (1978), iar din 1991 funcționează ca liceu teoretic cu profilurile real și uman. Astăzi, reprezintă un important centru educațional al cartierului Floreasca.', 'Liceu teoretic din cartierul Floreasca, înființat în 1957, astăzi cu profiluri real și uman.'),
(9, 'Cantemir Vodă', 'Colegiul Național Cantemir-Vodă își are originile în 1868, când a fost înființat ca Gimnaziul „Matei Basarab”. Din 1878 a primit numele „Cantemir-Vodă”, iar în 1919 a devenit liceu. De-a lungul timpului, instituția a depășit dificultăți precum lipsa unui sediu stabil, războaiele și cutremurele, construindu-și treptat actualul local.\n\nÎn perioada interbelică, liceul și-a consolidat prestigiul prin profesori de renume și rezultate remarcabile ale elevilor în științe, cultură și sport. După al Doilea Război Mondial, școala și-a continuat dezvoltarea, punând accent pe matematică, fizică și, ulterior, informatică.\n\nDupă 1990, a devenit liceu teoretic și apoi Colegiu Național (1996), fiind recunoscut pentru performanțele în informatică și pentru proiectele educaționale internaționale. Astăzi, colegiul este una dintre cele mai prestigioase instituții de învățământ din București, cu rezultate deosebite la olimpiade, activități extracurriculare și parteneriate europene', 'Colegiu național cu origini din 1868, prestigios pentru rezultatele la informatică și proiectele educaționale internaționale.'),
(10, 'Carol I', 'Colegiul Tehnic Carol I își are originile în 1935, odată cu înființarea Școlii de fete „Doamna Stanca”, destinată pregătirii profesionale a tinerelor. După reforma învățământului din 1948, școala a devenit Școala Comercială nr. 4, iar în 1963 s-a transformat în Liceul Teoretic nr. 25, cu profil real-umanist.\n\nÎn perioada 1977–1978, ca urmare a industrializării învățământului, a devenit Liceul Industrial „Tehnometal”, cu profil mecanic și electrotehnic, dezvoltând ateliere și colaborări cu importante întreprinderi industriale pentru pregătirea practică a elevilor.\n\nDupă 1990, școala s-a reorganizat, iar profilul educațional s-a diversificat prin introducerea specializărilor de informatică, optică, protecția mediului și mecatronică. În 2003 a primit denumirea de Grupul Școlar „Doamna Stanca”, iar din 2010 poartă numele actual de Colegiul Tehnic „Carol I”.\n\nBeneficiind de lucrări de modernizare și dotări noi după 2004, colegiul continuă și astăzi tradiția formării profesionale și tehnice, fiind condus în prezent de prof. dr. ing. Nicolof Vali-Ifigenia.', 'Colegiu tehnic cu origini din 1935, cu specializări tehnice moderne: informatică, optică, protecția mediului, mecatronică.'),
(11, 'Constantin Brâncuși', 'Viziunea reprezintă o stare ideală proiectată în viitor și care configurează o posibilă dezvoltare a școlii. Ea presupune pe termen lung șansele de dezvoltare ale școlii.', 'Instituție de învățământ din București, orientată spre dezvoltarea pe termen lung a școlii și a elevilor.'),
(12, 'Costin C. Kirițescu', 'COSTIN C. KIRIŢESCU, fiul lui Constantin Kiriţescu, profesor universitar doctor, autor de lucrări ştiinţifice, didactice, istorice, literare, memorialistice s-a născut în Bucureşti, pe data de 25 Mai 1908. Costin Kiriţescu a urmat şi absolvit mai multe instituţii de învăţământ superior: Conservatorul, Facultatea de Drept, precum şi Academia de Înalte Studii Comerciale şi Industriale, completându-şi astfel cultura umanistă, literară şi artistică, cu înalte studii juridice şi ştiinţifice. În 1934, și-a susținut teza de doctorat în cadrul Universității Friedrich Wilhem din Berlin. Întors în ţară, parcurge toate treptele ierarhiei didactice, predând succesiv cursuri la disciplinele Economie Politică, Politică Economică, Monedă, Legislaţie Agrară şi Drept Financiar. Din anul 1958 până la finalul carierei a lucrat ca specialist în cadrul Ministerului de Finanţe, reluându-și activitatea didactică universitară la Academia de Studii Economice din Bucureşti. Costin Kiriţescu, profesor şi academician, este autorul a peste 400 studii şi articole apărute în diverse publicaţii din ţară şi străinătate', 'Colegiu economic care poartă numele economistului și academicianului Costin C. Kirițescu.'),
(13, 'Costin D. Nenițescu', 'Viziunea școlii este de a deveni un model al formării și calificării profesionale la nivelul  standardelor europene, de a crea un cadru educațional competitiv și de a promova spiritului de inițiativă și creativitate cu scopul de a forma și a dezvolta personalitatea elevilor, pentru dezvoltarea unei comunități înfloritoare.', 'Instituție de învățământ tehnologic axată pe formarea și calificarea profesională la standarde europene.'),
(14, 'C-tin Brâncoveanu', 'Colegiul Național Constantin Brâncoveanu își are originile în perioada interbelică, când a fost construită școala din cartierul Costeasca prin contribuții publice („cărămizi”). Inițial a funcționat ca școală primară și complementară, iar în 1954 a devenit liceu sub denumirea „Școala Medie de Fete din Costeasca”.\n\nDe-a lungul timpului, instituția a trecut prin mai multe transformări: a devenit Liceul nr. 6, apoi Liceul „Dumitru Petrescu” (1972–1990). În 1976 și-a schimbat profilul în liceu industrial, pregătind elevi în domenii precum mecanică, electrotehnică, metalurgie și construcții.\n\nÎn 1990, liceul a revenit la profilul teoretic și a primit numele „Constantin Brâncoveanu”, adaptându-se reformelor educaționale și standardelor europene. De-a lungul existenței sale, a avut un rol important în coordonarea altor școli și grădinițe din zonă și s-a remarcat prin modernizarea continuă a procesului educațional.\n\nÎn 2001, instituția a sărbătorit 40 de ani de activitate în sediul actual, confirmându-și statutul de liceu cu tradiție și prestigiu în învățământul bucureștean.', 'Colegiu național cu origini interbelice, revenit la profilul teoretic în 1990, cu tradiție în învățământul bucureștean.'),
(15, 'Dacia', 'A fost înființat în anul 1925 ca Şcoală de Arte şi Meserii. În 1970 îşi schimbă sediul (pe actualul amplasament) şi devine Liceul Industrial numărul 9, funcționând cu clase de liceu industrial profil mecanic (mecanic auto și prelucrător prin așchiere), şcoală profesională (mecanic auto, tinichigiu auto, electrician  auto) și şcoală de maiştri (electromecanic auto). După anul 1990, funcționează sub denumirea de Grupul Şcolar Industrial DACIA, avînd în oferta educațională și clase de liceu teoretic: real (matematică,- informatică), uman (știintele naturii), liceu tehnologic(tehnician transporturi) și clase de seral cu profil auto.\n\n În anul 2012, școala își schimbă denumirea în Liceul Tehnologic DACIA', 'Liceu tehnologic înființat în 1925 (fostă Școală de Arte și Meserii), cu profil mecanic/auto și clase teoretice.'),
(16, 'Dante Alighieri', 'Liceul Teoretic Dante Alighieri a fost înființat în 1958 sub denumirea de Școala Medie Mixtă nr. 39. După mai multe schimbări de nume și profil, din 1992 funcționează ca Liceul Teoretic „Dante Alighieri”, fiind cunoscut pentru clasele bilingve româno-italiene.\n\nUn moment important în dezvoltarea sa a fost semnarea, în 2002, a Memorandumului româno-italian privind funcționarea secțiilor bilingve, care permite recunoașterea studiilor și facilitează accesul absolvenților la universitățile din Italia. Din 1996 au fost înființate și clase gimnaziale cu studiu intensiv al limbii italiene, iar din 2007 funcționează o clasă cu limba italiană ca limbă maternă.\n\nLiceul oferă specializări din filiera teoretică (matematică-informatică, științele naturii, filologie și clase bilingve), fiind dotat cu laboratoare moderne, bază sportivă și bazin de înot. Elevii obțin rezultate remarcabile la olimpiade și concursuri, iar promovabilitatea la examene este foarte ridicată.', 'Liceu teoretic cunoscut pentru clasele bilingve româno-italiene, cu laboratoare moderne, bază sportivă și bazin de înot.'),
(17, 'Decebal', 'Liceul Teoretic „Decebal” din sectorul 3, Bucureşti, este o instituţie şcolară înfiinţată în anul 1955.\nUnitatea noastră a evoluat de-a lungul timpului, schimbându-și atât denumirea, cât și statutul\n\n    1955 - Şcoala Profesională de Ucenici Constructori în cadrul Ministerului Construcţiilor şi Materialelor de Construcţii.\n    1960 - Centrul Şcolar Profesional de Construcţii\n    1964 - Grupul Şcolar de Construcţii Montaj Nr. 1\n    1971 - Liceul Industrial Nr. 18 - Bucureşti, odată cu mutarea în clădirea în care funcţionează şi în prezent\n    1990 - Liceul Teoretic „Decebal”, înfiinţarea ciclurilor primar şi gimnazial\n    2003 - Liceul Bilingv „Decebal”, introducerea regimului bilingv la majoritatea claselor\n    2012 - Liceul Teoretic Bilingv „Decebal”\n    2014 - Liceul Teoretic „Decebal”', 'Liceu teoretic din sectorul 3, înființat în 1955, care a funcționat o perioadă și în regim bilingv.'),
(18, 'Dimitrie Bolintineanu', 'Înfiinţat la 1 septembrie 1953 sub denumirea de \"Şcoala Normală de Băieţi Nr.23\", primeşte în anul 1959 denumirea de \"Liceul Teoretic Dimitrie Bolintineanu\" prin decret nr.257/1959 şi Ordinul Ministrului Athanase Joja nr.14/1959.\n\n     Liceul teoretic \"Dimitrie Bolintineanu\" situat in Bucuresti, in sectorul 5, in cartierul Rahova este de fapt un complex scolar care are in componenta sa toate nivelurile de studiu incepand de la cel primar si gimnazial si ajungand la liceu-cursuri de zi la clasele IX-XII.\n\n     Oferta educationala este generoasa. Pornind de la clasele I = 3 clase cu predare optional a limbii engleze, clasele a II-a in numar de 3 cu predare optional limba germana, clasele a III-a si a IV –a, fiecare nivel de cate 3 clase. La ciclul gimnazial clasele V-VIII cu limba engleza, franceza,germana. La liceu oferta cuprinde clase de matematica-informatica, clase de stiintele naturii, cate o clasa de stiinte sociale si clase de filologie.\n\n     Unitatea scolara “Dimitrie Bolintineanu” are o baza materiala foarte moderna si functionala. Astfel: 2 corpuri de cladire moderne, una pentru clasele V-XII – cu sali de clase dotate cu computer si videoproiector, cu laboratoare de fizica, chimie, biologie; celalalt corp de cladire construit recent pentru clasele I-IV – cu sali de clasa moderne, de asemenea biblioteca, cabinetul medical si cabinetul stomatologic si sala de festivitati. De asemenea exista o sala foarte mare (tip polivalent) de educatie fizica si sport si 2 bazine de inot care se afla in constructie. ', 'Complex școlar din sectorul 5 (cartierul Rahova), de la primar la liceu, cu bază materială modernă și ofertă teoretică variată.'),
(19, 'Dimitrie Gusti', 'Liceul Tehnologic „Dimitrie Gusti” este situat în mediu urban, în municipiul Bucureşti, are o vechime mai mare de un secol, fiind înfiinţat – ca şcoală de ucenici în 1904 sub numele de Şcoala de ucenici „Ghencea”. Mai târziu, prin anii ’50 se transformă în Şcoala profesională „Vulcan”, pregătind elevi pentru meserii sau specializări ale domeniului mecanic, construcţiilor de maşini. În anii ’60 când s-au format primele licee industriale, Şcoala profesională „Vulcan” a devenit Liceul Industrial nr. 3, având în componenţă pe lângă forma de învăţământ profesional şi liceul industrial. Începând cu anii ’80, şcoala parcurge din nou o perioadă de transformare diversificându-şi profilurile prin adăugarea unor noi forme de învăţământ ca liceul seral, liceul cu frecvenţă redusă şi şcoala de maiştri.  În 1995, la iniţiativa Inspectoratului Şcolar la Municipiului Bucureşti a fost schimbată denumirea instituţiei în Grup Şcolar Industrial „Dimitrie Gusti”. Conform OMECTS nr. 6564 din 13 decembrie 2011 privind aprobarea Procedurii de atribuire a denumirilor unităților de învățământ din sistemul național de învățământ preuniversitar, Grup Şcolar Industrial „Dimitrie Gusti” se numește Liceul Tehnologic „Dimitrie Gusti”.', 'Liceu tehnologic cu peste un secol de existență (din 1904), cu tradiție în domeniul mecanic.'),
(20, 'Dimitrie Leonida', 'Colegiul Tehnic Dimitrie Leonida își are originile în anul 1946, când clădirea a fost construită de industriașul Nicolae Malaxa pentru pregătirea profesională a tinerilor care urmau să lucreze în întreprinderile sale.\n\nÎn 1972, odată cu reînființarea liceului industrial, instituția și-a diversificat formele de învățământ, incluzând liceu industrial, școală profesională, școală postliceală și școală de maiștri. După 1990, fostul Grup Școlar Industrial „23 August” a primit numele „Dimitrie Leonida”, în onoarea inginerului român Dimitrie Leonida, personalitate importantă în domeniile electric și mecanic.\n\nDin anul școlar 2002–2003, instituția funcționează ca Colegiu Tehnic, având misiunea de a oferi o pregătire tehnică modernă și de calitate. Colegiul formează elevi în domenii tehnice la standarde europene, urmărind dezvoltarea competențelor profesionale, a spiritului creativ și a capacității de integrare pe piața muncii sau în învățământul superior. Astăzi, colegiul este recunoscut pentru tradiția sa în educația tehnică și pentru adaptarea permanentă la cerințele comunității și ale economiei moderne.', 'Colegiu tehnic cu origini din 1946, cu pregătire tehnică modernă la standarde europene.'),
(21, 'Dimitrie Paciurea', 'Liceul „Dimitrie Paciurea” din București, sectorul 1, este o instituție de învățământ preuniversitar de stat, situată în incinta Combinatului Fondului Plastic. Aici studiază aproximativ 350 de elevi.\n\nÎncepând cu anul școlar 2014–2015, liceul a cunoscut o dezvoltare semnificativă, devenind tot mai atractiv pentru elevi. Evoluția sa se bazează pe viziunea „Artă pentru elevi” și pe misiunea de a deveni o școală de arte decorative de referință la nivel național și european, prin îmbinarea armonioasă a artei cu tehnologia.\n\nLiceul oferă pregătire în domeniile Arte plastice și decorative, Conservare-restaurare bunuri culturale și Filologie. Noul Plan de Dezvoltare Instituțională urmărește integrarea formării artistice cu cea umanistă. Elevii de la filiera vocațională pot obține certificarea competențelor profesionale de nivel 4, care le facilitează accesul pe piața muncii, în special în domeniul conservării și restaurării patrimoniului cultural.', 'Liceu vocațional de arte din sectorul 1, cu specializări în arte plastice și decorative, conservare-restaurare și filologie.'),
(22, 'Dinicu Golescu', 'Colegiul Tehnic Dinicu Golescu are, conform atestărilor documentare, o vechime de 97 de ani; se află în vecinatatea podului Grant, a Stadionului şi a Teatrului Giuleşti, pe Calea Giuleşti nr. 10, sectorul 1, Bucureşti. Aceasta unitate şcolară a pregătit personal în domeniul feroviar între anii 1922 – 1974 funcţionând ca Şcoală Profesională C.F.R. În anul 1974 se înfiinţează Liceul Mecanic Nr.16 in paralel cu Şcoală Profesională pentu ca, dupa putin timp, sa devina Liceul Industrial nr. 11; intre anii 1991 – 2000 s-a numit Grup Scolar Industrial de Material Rulant. Din anul 2000 funcţionează sub denumirea de Colegiul Tehnic de Material Rulant pentru Transporturi Feroviare, iar din anul 2014 școala nostră se numește Colegiul Tehnic Dinicu Golescu.', 'Colegiu tehnic din sectorul 1, cu tradiție în domeniul feroviar și de material rulant.'),
(23, 'Dragomir Hurmuzescu', 'Liceul Tehnologic „Dragomir Hurmuzescu” este situat în sectorul 3 al Bucureștiului, în cartierul Nicolae Malaxa (fost „23 August”), o zonă care a trecut de la un caracter muncitoresc și periferic la unul modern și diversificat, ca urmare a dezvoltării imobiliare și a extinderii infrastructurii urbane.\n\nInstituția a fost înființată în anul 1974 prin fuziunea dintre Liceul Teoretic nr. 38 și Școala Profesională a Uzinei de Țevi „Republica”, fondată în 1969. De-a lungul timpului, liceul a pregătit elevi în numeroase domenii tehnice și teoretice, inclusiv metalurgie, electrotehnică, mecanică, automatizări, matematică-informatică și biologie-chimie.', 'Liceu tehnologic din sectorul 3, înființat în 1974, cu profiluri tehnice și teoretice variate.'),
(24, 'Dumitru Moțoc', 'Colegiul Tehnic de Industrie Alimentară „Dumitru Moțoc” este una dintre cele mai importante instituții de învățământ de profil alimentar din România, cu o tradiție începută în anul 1947. De-a lungul timpului, școala și-a extins baza materială și oferta educațională, pregătind elevi în diverse specializări ale industriei alimentare.\n\nInstituția a contribuit la modernizarea învățământului profesional și tehnic, fiind școală-pilot în programul PHARE VET și implicându-se în elaborarea de standarde ocupaționale și curriculumuri. De asemenea, a dezvoltat numeroase parteneriate cu agenți economici și instituții educaționale din țară și din străinătate.\n\nDin anul 2000, școala poartă denumirea de Colegiul Tehnic de Industrie Alimentară „Dumitru Moțoc”, în onoarea profesorului considerat fondatorul învățământului superior modern de industrie alimentară din România. Astăzi, colegiul continuă să ofere o pregătire profesională de calitate și să se implice în proiecte de dezvoltare și modernizare educațională.', 'Colegiu tehnic de industrie alimentară cu tradiție din 1947, una dintre cele mai importante școli de profil din România.'),
(25, 'Edmond Nicolau', '1 septembrie 1971 – se infiinleaza Scoala profesionali „Electronica”\n\n1septembrie 1974 – scoala devine: Grupul Scolar Industrial „Electronica”\n\n1 septembrie 2001 – scoala primeste denumirea actuala de: Colegiul Tehnic „Edmond Nicolau”, dupa numele parintelui romanesc al ciberneticii\n\n1 septembrie 1993 – Centru nalional de perfectionare al maistrilor instructori – profil electronic\n\n1 septembrie 1996 – Scoala de demonstratie in cadrul Programului PHARE VET RO 9405 .\n\n1 septembrie 1999 – Centru de perfectionare al maistrilor instructori, profilul electronica.\n\n1 septembrie 2000-2002 – Parteneriat Internalional in cadrul programului SOCRATES, mobilitati de elevi si profesori in tarile participante : Spania, Slovenia, Germania, ltalia.\n\nParteneriate in programe europene pentru licee vocationale Leonardo, cu unitati scolare din Bulgaria ( Liceul „Alexandr Popov”- Veliko Trnovo, 2007-2008; cu ‘Liceul ‘Stamen Panchev”- 2012-2013), de efectuare a unor stagii de practici in domeniile electronici si electrotehnica, 2015-2017;\n2013 – Academia Oracle (Cristina Andreescu) Incepand din anul scolar 2001-2002 „Grupul scolar Industrial ELECTRONICA” functioneaza sub denumirea de Colegiul Tehnic „Edmond Nicolau”.', 'Colegiu tehnic cu profil electronic, înființat în 1971, numit după părintele românesc al ciberneticii.'),
(26, 'Elena Cuza', 'Colegiul Național „Elena Cuza” din București își are originile în instituțiile educaționale create sub patronajul Elenei Cuza și al lui Carol Davila încă din secolul al XIX-lea, având o tradiție îndelungată în formarea educatoarelor și învățătoarelor.\n\nÎn forma sa actuală, instituția a fost înființată la 1 septembrie 1971 sub denumirea de Liceul Pedagogic de Educatoare. În 1981 s-a comasat cu Liceul Pedagogic de Învățători, funcționând ca Liceul Pedagogic București. După 1990, a purtat denumirile de Școala Normală și Școala Normală „Elena Cuza”, iar din 1999 funcționează ca Colegiul Național „Elena Cuza”.\n\nAstăzi, colegiul continuă tradiția pedagogică a instituției, fiind una dintre cele mai prestigioase școli din București pentru formarea viitoarelor cadre didactice și pentru educația de calitate.', 'Colegiu național cu tradiție pedagogică, dedicat formării cadrelor didactice.'),
(27, 'Elie Radu', 'Colegiul Tehnic Elie Radu oferă populaţiei şcolare din Ploieşti şi din zonă, oportunităţi de  educaţie şi instruire de cea mai bună calitate în domeniile electric, electromecanic, mecanic şi construcţii şi lucrări publice, sprijinind în acelaşi timp dezvoltarea carierei, sporirea calităţii vieţii şi prosperitatea economică.', 'Colegiu tehnic cu pregătire în domeniile electric, electromecanic, mecanic și construcții.'),
(28, 'Emil Racoviță', 'Colegiul National „Emil Racovita“ din Bucuresti (CNER) este o institutie de invatamant primar, gimnazial si liceal din Bucuresti, sectorul 2. CNER are oferta educationala pentru clasele I-XII, respectiv pentru clasa pregatitoare si un specific sportiv aici pregatindu-se inotatori, poloisti, saritori in bazin, dar si practicanti ai altor sporturi, precum tenis, pentatlon modern sau atletism CNER poarta in spatele sau 166 de ani de istorie si performanta, numeroase personalitati ale vietii publice romanesti invatand aici pana in prezent. La loc de cinste vor sta intotdeauna in istoria CNER nume recunoscute international pe plan sportiv precum multipla campioana olimpica si mondiala la gimnastica Nadia Comaneci, multiplul campion mondial la gimnastica Marian Dragulescu, fotbalistul Florin Radu Raducioiu, tenismanii Raluca Olaru si Victor Hanescu, inotatorul Dragos Coman, atletul Sorin Matei, pentatlonistul Adrian Toader, poloistii Florin Musat si Tiberiu Negrean si multi altii (pentru detalii va rugam sa accesati ', 'Colegiu național din sectorul 2 cu profil sportiv puternic (înot, polo, sărituri) și o istorie de peste 160 de ani.'),
(29, 'Energetic', 'Scoala dispune de resurse umane cu pregatire didactica deosebita, de resurse materiale si financiare, care permit elevilor pe langa o pregatire de cultura generala si de specialitate deschiderea catre valorile culturale, ale lumii actuale. Colegiul Tehnic Energetic, denumire sub care este cunoscut din anul 2001 are o lunga istorie.', 'Colegiu tehnic cu profil energetic, cunoscut sub această denumire din 2001, cu o lungă istorie.'),
(30, 'Eugen Lovinescu', 'Infiintat in 1910 sub numele de Scoala de Arte si Meserii, a functionat astfel pana in 1924 si a pregatit de-a lungul timpului specialisti in domeniul energetic.', 'Instituție înființată în 1910 (fostă Școală de Arte și Meserii), cu tradiție în domeniul energetic.'),
(31, 'George Călinescu', 'Pastrandu-si traditia, scoala a functionat si pe timpul razboiului, sub ocupatie germana, atat in Iasi cat si in Bucuresti, intre anii 1916 -1918 asigurand pregatirea de specialitate.', 'Școală cu tradiție îndelungată, care a asigurat pregătirea de specialitate inclusiv în timpul Primului Război Mondial.'),
(32, 'George Coșbuc', 'In anul 1995 intra in programul Phare VET Ro 9405 ca scoala de demonstratie in domeniul energetic si astfel beneficiaza de o dotare deosebita a laboratoarelor de specialitate. Este de mentionat faptul ca elevii...', 'Liceu bilingv din București, cu laboratoare de specialitate dotate prin programul Phare VET.'),
(33, 'Gheorghe Airinei', 'Colegiul Tehnic de Poștă și Telecomunicații „Gheorghe Airinei” din București a fost înființat în 1942 ca Școală Medie Tehnică de Telecomunicații, având rolul de a forma tehnicieni pentru sectorul poștal și de telecomunicații.\n\nÎn 1966 devine Liceul de Poștă și Telecomunicații, iar în 1970 se transformă în Grup Școlar, funcționând în actualul sediu din sectorul 6. Din anul 2000, instituția poartă denumirea actuală.\n\nLiceul oferă și clase bilingve de engleză și franceză, fiind unul dintre puținele din București cu acest profil, în colaborare cu Ambasada Franței. Din 2005, funcționează ca centru de evaluare pe competențe pentru meserii din domeniu, fiind acreditat CNFPA, ceea ce îi consolidează rolul în formarea specialiștilor în telecomunicații.', 'Colegiu tehnic de poștă și telecomunicații (din 1942), cu clase bilingve de engleză și franceză.'),
(34, 'Gheorghe Asachi', 'Liceul a fost înființat în anii ’70 cu denumirea de Liceul Industrial nr. 28, profil industrie ușoară și mecanică.  După 1990 a funcționat ca Grupul Școlar Industrial de Confecții și Tricotaje iar din 1994 Grupul Școlar Industrial \"Gheorghe Asachi\".  În septembrie 2009, liceul s-a transformat în Colegiul Tehnic \"Gheorghe Asachi\", oferind noi specializări în cadrul profilului tehnic.', 'Colegiu tehnic din anii ’70 (fost profil industrie ușoară și mecanică), cu specializări tehnice.'),
(35, 'Gheorghe Lazăr', 'Colegiul Național „Gheorghe Lazăr” din București a fost înființat în 1860 de Alexandru Ioan Cuza, devenind unul dintre primele licee românești. În 1890, a fost inaugurat localul actual de lângă Cișmigiu, iar școala s-a dezvoltat rapid, mai ales în perioada reformelor lui Spiru Haret, devenind un important centru educațional și cultural.\n\nDe-a lungul timpului, liceul a fost cunoscut pentru activitățile sale științifice, culturale și sportive, precum și pentru formarea unor personalități importante. În perioada comunistă a trecut prin schimbări de nume și structură, dar și-a menținut prestigiul.\n\nDupă 1989, a revenit la tradițiile sale și a continuat să fie una dintre cele mai bune școli din România, cu rezultate academice și extracurriculare deosebite.', 'Colegiu național înființat în 1860 de Al. I. Cuza, unul dintre primele licee românești, situat lângă Cișmigiu.'),
(36, 'Gheorghe Șincai', 'Colegiul Național „Gheorghe Șincai” din București își are originile la sfârșitul secolului al XIX-lea, când, pe lângă Liceul ??Matei Basarab”, au fost create mai multe clase divizionare pentru numărul mare de elevi. Acestea au dus, în 1892, prin decret regal semnat de Carol I, la înființarea Gimnaziului Clasic „Gheorghe Șincai”.\n\nÎn 1919, gimnaziul devine liceu, iar între 1924–1928 începe construcția actualului sediu. După reforma din 1948, instituția a trecut prin mai multe reorganizări și denumiri, funcționând ca liceu de băieți și fete, apoi ca școală medie mixtă.\n\nÎn 1956–1957, școala își recapătă denumirea de „Gheorghe Șincai”, devenind din nou o instituție de referință în învățământul bucureștean, cu tradiție solidă și evoluție continuă.', 'Colegiu național cu origini din 1892, instituție de referință în învățământul bucureștean.'),
(37, 'Goethe', 'Colegiul German „Goethe” din București este o instituție a minorității germane, aflată în subordinea Ministerului Educației și Cercetării din România, cu predare integrală în limba germană. Admiterea se face pe baza unui test de competență lingvistică, iar elevii sunt integrați într-un sistem educațional bilingv, în care încă din clasele primare toate disciplinele sunt predate în germană, iar din clasa a III-a se studiază și limba engleză.\n\nÎn gimnaziu, elevii își consolidează cunoștințele de cultură generală și își dezvoltă competențele necesare pentru evaluarea națională, iar în liceu pot urma profiluri reale sau umaniste, inclusiv specializări precum matematică-informatică sau științe sociale-filologie.\n\nAbsolvenții obțin certificări lingvistice recunoscute atât în România, cât și în Germania (Deutsches Sprachdiplom), ceea ce le facilitează continuarea studiilor în spațiul german sau internațional.', 'Colegiu german cu predare integrală în limba germană și certificări recunoscute în România și Germania (DSD).'),
(38, 'Grigore Cerchez', 'Colegiul Tehnologic „Grigore Cerchez” din București este o instituție de învățământ tehnologic care urmărește formarea elevilor prin valori precum disciplina, respectul, responsabilitatea, spiritul de echipă și toleranța, cu scopul adaptării lor la cerințele societății moderne.\n\nȘcoala are o istorie complexă, începută în 1908, când a fost construită clădirea inițială. De-a lungul timpului, instituția a trecut prin mai multe etape: școală de arte și meserii (din 1931), școală de ucenici și profesională în perioada comunistă, apoi Liceul Industrial „Autobuzul” (din 1976). În 1998 a primit denumirea „Grigore Cerchez”, iar din 2009 funcționează sub actuala titulatură de colegiu tehnologic.\nAstăzi, instituția își continuă misiunea de a oferi o educație tehnologică adaptată prezentului, formând elevi capabili să se integreze eficient în mediul profesional și social.', 'Colegiu tehnologic cu istorie din 1908, axat pe disciplină, responsabilitate și integrare profesională.'),
(39, 'Grigore Moisil', 'Colegiul Național „Grigore Moisil” este un liceu teoretic din București cu clase specializate în matematică-informatică, științe ale naturii, științe sociale și filologie.  A fost fondat în anul 1965 pe lângă „Școala Normală” care a funcționat în clădirea atașată Colegiului Elena Doamna. Până în 1967 a funcționat pe rând în incinta Școlii Generale 193, a liceului Tudor Vladimirescu, apoi s-a mutat în propria clădire din cartierul Drumul Taberei, unde a devenit Liceul nr. 33. Începând din anul 1990 poartă numele academicianului Grigore Moisil.', 'Colegiu național cu profil teoretic (matematică-informatică, științe, social, filologie), fondat în 1965.'),
(40, 'Henri Coandă', 'Colegiul Tehnic de Aeronautică „Henri Coandă” din București a fost înființat în 1972 și este singura instituție din România cu profil aeronautic. A funcționat de-a lungul timpului sub mai multe denumiri și a pregătit elevi în domenii tehnice precum aviația, mecanica și electrotehnica.\n\nAflat în apropierea unor importante companii și structuri din industria aeronautică, colegiul a colaborat constant cu specialiști din domeniu, oferind elevilor pregătire practică de specialitate.\n\nDupă 1990, oferta educațională s-a diversificat, iar școala a fost inclusă în programe europene și în sistemul de învățământ dual, continuând să formeze specialiști pentru industria aviației.', 'Colegiu tehnic de aeronautică (din 1972), singura instituție cu profil aeronautic din România.'),
(41, 'Hermes', 'Colegiul Economic „Hermes” din București are o tradiție care începe în 1869, odată cu înființarea unui pension pentru fete de către Victoria Choisy. De-a lungul timpului, instituția a trecut prin numeroase transformări, adaptându-se schimbărilor sociale și educaționale.\n\nÎn secolul XX a funcționat sub diverse denumiri și profiluri, în principal economic și tehnic, evoluând treptat către forma actuală. Din anul 2000, poartă denumirea de Colegiul Economic „Hermes” și continuă să pregătească elevi în domeniul economic, având o tradiție solidă în educație și formare profesională.', 'Colegiu economic cu tradiție din 1869, cu profil economic.'),
(42, 'Hristo Botev', 'Liceul Teoretic Bulgar a fost infintat in anul 1998 prin Ordinul Ministerului  Educatiei nattionale nr. 4981 din 10.11.1998. pe baza unui acord intre Romania si Bulgaria, ca unitate de invatamant de stat cu predare in limba romana si avand ca obiectiv de studiu obligatoriu limba bulgara.\nIncepand cu anul scolar 2005-2006, liceul si-a schimbat denumirea in Liceul Teoretic Bulgar \"Hristo Botev\". Tot in acest an, a fost inaugurata cladirea consolidat si renovata, care oferaa un mediu propice pentru desfasurarea procesului  educativ.\nIn perspctiva dezvoltarii liceului, la data de 10 septembrie 2005 a fost incheiat un Protocal de colaborare intre Comunitatea Elena din Romania si liceul nostru, permitand ca anul scolar 2006-2007, sa se infinteze si clase cu predare a limbii neograca.', 'Liceu teoretic bulgar, înființat în 1998, cu studiul obligatoriu al limbii bulgare.'),
(43, 'I.L.Caragiale', 'La sfârșitul secolului al XIX-lea, în contextul modernizării învățământului românesc, au fost înființate Școlile Normale Superioare din București și Iași pentru formarea profesorilor de elită, cu secții literare și științifice.\n\nInstituția din București a fost condusă de personalități importante precum Ion Zalomit, Nicolae Quintescu și Alexandru Odobescu, iar printre profesorii săi s-au numărat mari figuri ale culturii române, precum Gheorghe Țițeica și Constantin Rădulescu-Motru.\n\nDe-a lungul timpului, școala a devenit Seminar Pedagogic, apoi Școală Normală Superioară și Academie Pedagogică. În prezent, în același local funcționează Colegiul Național „I. L. Caragiale” din București, continuând tradiția educațională a instituției.', 'Colegiu național cu origini în Școala Normală Superioară din secolul al XIX-lea, cu tradiție educațională de prestigiu.'),
(94, 'Internațional Ioanid', 'Liceul Internațional Ioanid este o instituție privată modernă din București, care oferă un program educațional bazat pe curriculumul național, dar și pe standarde internaționale. Liceul pune accent pe o educație de calitate, axată pe dezvoltarea integrală a elevilor și pe promovarea unui mediu multiculturale. În plus, elevii beneficiază de pregătire în limba engleză și participă la diverse activități extracurriculare care le dezvoltă abilități esențiale pentru viitor. Acesta se află în zona centrală a capitalei și colaborează cu diverse organizații educaționale și de afaceri internaționale. \n\nInstituția se remarcă printr-un curriculum modern și adaptat nevoilor actuale ale elevilor, integrând atât programa națională, cât și programe internaționale, precum Bacalaureatul Internațional (IB) și Cambridge. ', 'Liceu privat din zona centrală, cu curriculum național și internațional (IB și Cambridge) și accent pe limba engleză.'),
(44, 'Ioan N. Socolescu', 'Colegiul Tehnic de Arhitectură și Lucrări Publice „I. N. Socolescu” își are originea în Școala de Arte și Meserii înființată în 1884 de Societatea „Unirea Constructorilor Români”, la inițiativa arhitectului Ion N. Socolescu. Școala a combinat încă de la început pregătirea teoretică cu practica pe șantier, având ca scop formarea de tehnicieni în construcții și arhitectură.\n\nÎn timp, instituția a trecut prin mai multe transformări administrative și de denumire: a devenit școală de stat în 1910, apoi a fost reorganizată succesiv de diverse ministere, iar după reforma din 1948 a funcționat ca școală tehnică de arhitectură. Ulterior a continuat ca grup școlar și liceu industrial, adaptându-se nevoilor domeniului construcțiilor.\n\nDin 2001 poartă denumirea actuală de colegiu tehnic, păstrând tradiția formării specialiștilor în arhitectură și lucrări publice.', 'Colegiu tehnic de arhitectură și lucrări publice, cu origini din 1884, îmbinând teoria cu practica pe șantier.'),
(45, 'Ion Barbu', 'Liceul de pe strada Năbucului nr. 18 își începe activitatea în 1960 ca Școala Medie nr. 36, ulterior trecând prin mai multe reorganizări și schimbări de profil. Între 1967 și 1977 funcționează ca liceu teoretic cu predare în limba franceză, apoi devine succesiv Liceul Teoretic nr. 9 și Liceul de Științe ale Naturii nr. 1, cu profil real axat pe chimie-biologie.\n\nÎn anii ’80 este transformat în Liceul Industrial nr. 35, iar din 1991 își consolidează profilul teoretic, real și uman, sub numele actual de Liceul Teoretic „Ion Barbu”, păstrând tradiția formării elevilor în domenii științifice și umaniste.', 'Liceu teoretic (din 1960), cu profil real și uman și tradiție în domenii științifice și umaniste.'),
(46, 'Ion Creangă', 'Colegiul Național „Ion Creangă” din București apare în contextul dezvoltării educației din perioada interbelică (1922–1928), când se resimte nevoia extinderii rețelei de licee și în cartierele periferice. Inițiativa înființării îi aparține unui comitet local condus de prof. dr. Christian Mușceleanu, care a susținut necesitatea unui nou liceu în zonă.\nÎn urma demersurilor făcute către Ministerul Instrucțiunii Publice, instituția este aprobată  începe să funcționeze de la 1 septembrie 1926, ca răspuns la nevoia de acces mai echitabil la educație în capitală.', 'Colegiu național din perioada interbelică (1926), creat pentru acces mai echitabil la educație în zonele periferice.'),
(47, 'Ion I.C. Brătianu', 'Liceul Tehnologic „Ion I.C. Brătianu” din București oferă pregătire tehnică la standarde europene pentru elevii din Capitală și din zonele învecinate. Instituția urmărește formarea unor tineri autonomi, creativi și bine pregătiți profesional, capabili să se integreze pe piața muncii, să își continue studiile sau să își dezvolte propriile afaceri.\n\nMisiunea școlii este de a asigura o educație de calitate, adaptată nevoilor comunității și cerințelor societății moderne, printr-un învățământ modern și orientat spre performanță. Viziunea sa este de a deveni un model de formare profesională la nivel european.', 'Liceu tehnologic cu pregătire tehnică la standarde europene, orientat spre integrarea pe piața muncii.'),
(48, 'Ion Neculce', 'Colegiul Național „Ion Neculce” din București a fost înființat în anul 1922, la inițiativa comunității din zona Gării de Nord și a profesorului Ioan I. Roman. De-a lungul timpului, instituția a purtat mai multe denumiri, primind numele „Ion Neculce” în 1958 și devenind colegiu național în 2010.\n\nȘcoala s-a remarcat prin caracterul său inovator, fiind una dintre primele din România organizate pe cabinete și laboratoare specializate, inclusiv cu laboratoare moderne de limbi străine și informatică. Astăzi, Colegiul Național „Ion Neculce” este recunoscut pentru rezultatele foarte bune la examene, proiectele educaționale naționale și internaționale și activitățile culturale și de dezbateri desfășurate de elevi.', 'Colegiu național înființat în 1922, recunoscut pentru rezultatele la examene și proiectele educaționale.'),
(49, 'Ita Wegman', 'Liceul Teoretic Bilingv „Ita Wegman” din București a fost înființat în anul 2002 și funcționează în cadrul alternativei educaționale Waldorf. Școala oferă învățământ primar, gimnazial și liceal, cu studiere intensivă și bilingvă a limbii germane.\n\nInstituția se remarcă prin promovabilitatea ridicată la Bacalaureat, profesorii specializați, activitățile artistice și educative diverse, precum și prin numeroase proiecte și parteneriate educaționale. Școala promovează valori precum respectul, cooperarea, responsabilitatea și dezvoltarea armonioasă a elevilor, în colaborare strânsă cu familiile și comunitatea.', 'Liceu teoretic bilingv (germană) din alternativa educațională Waldorf, înființat în 2002.'),
(50, 'Iulia Hașdeu', 'Colegiul Național „Iulia Hasdeu” oferă un învăţământ la standarde europene prin dascălii săi foarte bine pregătiţi profesional.\r\nElevii au rezultate deosebite la concursuri și olimpiade la disciplinele: limba spaniolă, limba engleză, lingvistică, limba și literatura română, istorie, biologie, chimie, fizică, matematică, informatică, latină, religie.\r\n\r\nAbsolvenţii secţiei bilingve româno-spaniole pot obţine şi diplomă spaniolă de bacalaureat, în baza acorduluiîntre MEN din România și Ministerul Educației și Știnței din Regatul Spaniei, începând cu septembrie 2007. Aceștia beneficiază de prezenţa unui profesor nativ de limbă spaniolă.', 'Colegiu național cu secție bilingvă româno-spaniolă; absolvenții pot obține și diploma spaniolă de bacalaureat.'),
(51, 'Iuliu Maniu', 'Înființat la 1 septembrie 1966, sub denumirea de „Liceul Industrial de Transporturi”, școala noastră a schimbat, de-a lungul timpului, mai multe denumiri și mai multe sedii. Este Colegiul Tehnic „Iuliu Maniu” din noiembrie 2006 și are mai multe forme de învățământ, profile și specializări.', 'Colegiu tehnic înființat în 1966 (fost Liceul Industrial de Transporturi), cu profile și specializări multiple.'),
(52, 'Jean Monnet', 'Liceul Teoretic „Jean Monnet” din București a fost înființat în anul 1963 sub denumirea de „Școala secundară mixtă nr. 24”. De-a lungul timpului, instituția a purtat mai multe denumiri, printre care Liceul nr. 24, Liceul de Matematică–Fizică nr. 2, Liceul Industrial nr. 32 și Liceul Teoretic „George Călinescu”.\n\nDin anul 1992, școala poartă numele de Liceul Teoretic „Jean Monnet”. Instituția s-a remarcat ca un liceu de elită, fiind unul dintre puținele licee de matematică–fizică din București care și-au păstrat profilul în perioada comunistă.', 'Liceu teoretic de elită (fost matematică-fizică), care și-a păstrat profilul real în perioada comunistă.'),
(53, 'Logos', 'Liceul Teologic Baptist „Logos” își are originile în tradiția educațională a comunității baptiste din România, care a promovat educația și studiul încă din secolul al XIX-lea. După schimbările democratice din 1989 și apariția cadrului legal pentru școlile confesionale, instituția și-a început activitatea la 1 septembrie 1990, prin ordin ministerial și hotărârea Secretariatului pentru Culte.\n\nLiceul continuă tradiția învățământului baptist din România, începută prin Seminarul Baptist înființat în 1921.', 'Liceu teologic baptist, cu activitate din 1990, continuând tradiția învățământului baptist din România.'),
(54, 'Lucian Blaga', 'Liceul Teoretic „Lucian Blaga” își are originile în școlile din cartierul Pantelimon, care au funcționat încă din anii 1940. În 1957, Școlile nr. 64 și nr. 65 s-au unit sub denumirea de Școala Medie Mixtă nr. 29 „Alexandru Sahia”, instituția dezvoltându-se treptat prin construirea unor noi clădiri și extinderea bazei materiale.\n\nÎn perioada 1977–1990, liceul a funcționat ca Grupul Școlar Industrial „Alexandru Sahia”. După 1990, a revenit la profilul teoretic și a primit numele de Liceul Teoretic „Lucian Blaga”, pe care îl păstrează și astăzi, având specializări în domeniile real și uman', 'Liceu teoretic din cartierul Pantelimon, revenit la profil teoretic (real și uman) după 1990.'),
(55, 'Marin Preda', 'Liceul Teoretic „Marin Preda”, înfiinţat la 1 septembrie 1999 prin fuziunea Şcolii Generale nr. 166 şi a Liceului Teoretic „Doamna Stanca”, îşi are sediul într-un frumos parc între cartierele Giuleşti şi Crângaşi. Corpul vechi al liceului a fost finalizat în 1963, iar cel nou în 1998.\n\nClădirile au 42 de săli de clasă, trei laboratoare (fizică, chimie, biologie), cinci cabinete (limbă și comunicare, educație muzicală, educație plastic, educație juridică, geografie), o sală de sport și un teren de sport.\n\nÎn liceu, învață peste 1.600 de copii, de la clasa pregătitoare la clasa a XII-a. Cele 62 de clase au profil real (specializările Matematică – Informatică și Știinte al Naturii) și uman (specializările Științe Sociale și Filologie). ', 'Liceu teoretic mare (peste 1.600 de elevi) între Giulești și Crângași, cu profil real și uman și bază materială modernă.'),
(56, 'Matei Basarab', 'Colegiul Național „Matei Basarab” își are originile în anul 1859, când a fost înființat prin decret al domnitorului Alexandru Ioan Cuza. În 1865 a devenit al doilea liceu din București, iar din 1885 funcționează în actualul sediu, extins și modernizat de-a lungul timpului.\n\nDe-a lungul existenței sale, instituția s-a remarcat prin performanțele academice, profesorii de prestigiu și numeroșii absolvenți care au devenit personalități ale culturii și științei românești. Din 1998 poartă titulatura de Colegiu Național, iar din 1999 are statut de școală pilot, confirmând rolul său important în învățământul românesc.', 'Colegiu național cu origini din 1859, școală-pilot cu performanțe academice și absolvenți de prestigiu.'),
(57, 'Media', 'nvățământul de profil poligrafic din București a fost înființat în 1948 prin crearea Școlii Medii Tehnice de Arte Grafice și a Școlii Profesionale de Arte Grafice „Dimitrie Marinescu”. În urma mai multor reorganizări, instituția a funcționat sub diferite denumiri, printre care Liceul Industrial de Poligrafie și Cinematografie și Liceul Industrial nr. 16.\n\nDin anul școlar 2000–2001, poartă numele de Colegiul Tehnic „Media”, fiind singurul liceu din România specializat în pregătirea elevilor pentru domeniile poligrafiei și cinematografiei', 'Colegiu tehnic cu profil poligrafic și cinematografic, singurul de acest fel din România.');
