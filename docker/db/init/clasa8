DROP TABLE IF EXISTS `home_numa_liceu`;
CREATE TABLE IF NOT EXISTS `home_numa_liceu` (
  `id_numa_liceu` int(5) UNSIGNED ZEROFILL NOT NULL AUTO_INCREMENT,
  `tip` varchar(100) NOT NULL,
  `name` varchar(100) NOT NULL,
  `description` text NOT NULL,
  `city` varchar(100) NOT NULL,
  `zone` varchar(100) NOT NULL,
  `address` varchar(255) NOT NULL,
  `photo` varchar(250) NOT NULL,
  `no_clase` int(3) NOT NULL DEFAULT '0',
  `total_no_student` int(3) NOT NULL DEFAULT '0',
  `romi_student` int(3) NOT NULL DEFAULT '0',
  `ces_student` int(3) NOT NULL DEFAULT '0',
  `avrg_medie` decimal(5,2) NOT NULL DEFAULT '0.00',
  `position` int(3) NOT NULL DEFAULT '0',
  `web_page` varchar(200) NOT NULL,
  `short_description` text NOT NULL,
  `long_description` text NOT NULL,
  `created_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `updated_at` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `created_by` int(4) UNSIGNED ZEROFILL NOT NULL DEFAULT '0000',
  `updated_by` int(4) UNSIGNED ZEROFILL NOT NULL DEFAULT '0000',
  `stopx` int(1) NOT NULL DEFAULT '0',
  PRIMARY KEY (`id_numa_liceu`),
  UNIQUE KEY `name` (`name`)
) ENGINE=MyISAM AUTO_INCREMENT=95 DEFAULT CHARSET=utf16;

